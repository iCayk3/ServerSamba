local.file_match "samba_audit" {
  path_targets = [{
    __address__ = "localhost",
    __path__    = "/var/log/samba/log.*",
    job         = "samba",
  }]
}

loki.source.file "samba_audit" {
  targets    = local.file_match.samba_audit.targets
  forward_to = [loki.write.local.receiver]
}

loki.write "local" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}
